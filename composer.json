{
    "name": "imperazim/libcommand",
    "description": "Command library for PocketMine plugins",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "imperazim\\command\\": "src/imperazim/command"
        }
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "lint": "@php .github/scripts/lint.php",
        "analyse": "@php .github/scripts/analyse.php",
        "test": "@php .github/scripts/test.php",
        "quality": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}
